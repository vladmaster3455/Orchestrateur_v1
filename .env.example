# ============================================================
# fichier de configuration - copiez ce fichier en .env
# et remplissez vos vraies valeurs (.env est dans .gitignore)
# ============================================================

# --- cle du LLM principal ---
# recuperez votre cle sur le site du fournisseur
ANTHROPIC_API_KEY=votre_cle_ici

# --- modele LLM a utiliser ---
# exemple avec Claude : claude-haiku-4-5
# exemple avec Ollama/LLaMA3 : llama3
LLM_MODEL=claude-haiku-4-5

# --- modeles de fallback (optionnel) ---
# liste separee par des virgules, essayes dans l'ordre si le modele principal echoue
# laisser vide si vous voulez utiliser uniquement LLM_MODEL
LLM_FALLBACK_MODELS=claude-3-5-haiku-latest,claude-3-5-sonnet-latest

# --- cle LLM rapide optionnel ---
# compte gratuit disponible sur le site du fournisseur
# laisser vide si vous n'en avez pas
GROQ_API_KEY=votre_cle_groq_ici

# --- service d'envoi d'emails ---
# compte gratuit, 300 emails/jour offerts
BREVO_API_KEY=votre_cle_emails_ici
EMAIL_FROM=votre-adresse@example.com

# --- LLM local via Ollama (optionnel) ---
# utilise si vous voulez tourner LLaMA3 en local
# installez Ollama depuis https://ollama.ai puis : ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
